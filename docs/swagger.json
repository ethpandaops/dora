        "handlers.APIExecutionClientsResponse": {
            "type": "object",
            "properties": {
                "clients": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handlers.APIExecutionClientNodeInfo"
                    }
                },
